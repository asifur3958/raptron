{
  "version": 2,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/client/assets/$1" },
    { "source": "/favicon.png", "destination": "/client/favicon.png" },
    { "source": "/logo.png", "destination": "/client/logo.png" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
